{
   "compilerOptions": {
      "strict": true,
      "module": "ESNext",
      "target": "ESNext",
      "moduleResolution": "node",
      "esModuleInterop": true,
      "noEmitOnError": true,
      "skipLibCheck": true,
      "types": ["node", "chrome", "jest"]
   },
   "exclude": ["node_modules"]
}