{
   "compilerOptions": {
      "strict": true,
      "target": "ESNext",
      "module": "nodenext",
      "moduleResolution": "nodenext",
      "isolatedModules": true,
      "esModuleInterop": true,
      "noEmitOnError": true,
      "skipLibCheck": true,
      "types": ["node", "chrome", "jest"]
   },
   "exclude": ["node_modules"]
}