{
  "name": "instagram-pic-enlarger",
  "version": "1.0.0",
  "description": "Opens profile's enlarged picture from the current tab to a new tab",
  "engineStrict": false,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "build": "webpack --config ./webpack.config.js",
    "playwright:setup": "yarn playwright install --with-deps chromium",
    "playwright:test": "yarn playwright test --config=tests/playwright/playwright.config.ts",
    "test": "yarn jest --config=tests/jest/jest.config.ts",
    "prettier": "prettier --check '**/*.{js,jsx,ts,tsx,css,html}'",
    "prettier:fix": "prettier --write '**/*.{js,jsx,ts,tsx,css,html}'",
    "typecheck": "tsc --noEmit",
    "lint": "yarn oxlint --type-aware"
  },
  "npmMinimumReleaseAge": 60,
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.40",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "copy-webpack-plugin": "^14.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "6.0.3",
    "webpack": "^5.106.1",
    "webpack-cli": "^7.0.2"
  },
  "resolutions": {
    "minimatch": "^9.0.7",
    "picomatch": "^4.0.4",
    "serialize-javascript": "^7.0.5"
  }
}
