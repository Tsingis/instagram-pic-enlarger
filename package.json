{
  "name": "instagram-pic-enlarger",
  "version": "1.0.0",
  "description": "Opens profile's enlarged picture from the current tab to a new tab",
  "scripts": {
    "build": "webpack --config ./webpack.config.js",
    "playwright:setup": "playwright install --with-deps chromium",
    "playwright:test": "playwright test --config=tests/playwright/playwright.config.ts",
    "test": "jest --config=tests/jest/jest.config.ts",
    "format": "oxfmt --check '**/*.{js,jsx,ts,tsx,css,html}'",
    "format:fix": "oxfmt '**/*.{js,jsx,ts,tsx,css,html}'",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/chrome": "^0.1.43",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "copy-webpack-plugin": "^14.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.0",
    "typescript": "6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "resolutions": {
    "minimatch": "^9.0.7",
    "picomatch": "^4.0.4",
    "serialize-javascript": "^7.0.5"
  },
  "engines": {
    "node": ">=22"
  },
  "engineStrict": false,
  "packageManager": "yarn@4.16.0+sha512.5374c94eb4ef6aa8188fb112f20c1aa6569f248d676c5e576e1fd2a1a4d8d87a96df65d9dfe1c2a0252cbe38bda46cf18d955005b81b43cc7607a5c9d56fd2b6"
}
